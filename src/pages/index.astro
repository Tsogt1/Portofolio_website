---
import Layout from "../layouts/Layout.astro";

const contact = {
  email: "tsoglog.uli@gmail.com",
  linkedin: "https://www.linkedin.com/in/tsogt-batjargal/",
  github: "https://github.com/Tsogt1",
  location: "Calgary, AB, Canada",
};

const skillGroups = [
  {
    title: "Data engineering",
    skills: ["Apache Airflow / Astronomer", "ETL / ELT", "Change Data Capture", "Incremental pipelines", "Data modeling", "Parquet", "Kafka"],
  },
  {
    title: "Warehouse & SQL",
    skills: ["Snowflake", "Streams / Tasks / Procs", "RBAC & masking", "SQL", "MySQL", "PostgreSQL", "SAP HANA"],
  },
  {
    title: "Cloud",
    skills: ["Azure Data Factory", "Synapse", "Azure Functions", "Blob / ADLS", "Key Vault", "Azure DevOps", "AWS (S3, Glue, Redshift, Lambda)"],
  },
  {
    title: "DataOps & IaC",
    skills: ["Terraform", "CI/CD", "OIDC / workload identity federation", "Docker / Podman", "Git", "Linux", "systemd", "Proxmox"],
  },
  {
    title: "Languages & BI",
    skills: ["Python", "C# / .NET", "Bash", "PowerShell", "R", "Power BI", "Tableau"],
  },
  {
    title: "Industrial IT / OT",
    skills: ["SCADA / PLC", "OSIsoft PI", "DCS / Ignition", "IT–OT data integration"],
  },
];

const growing = ["Databricks / Spark", "dbt (to prod)", "Kubernetes", "Prometheus / Grafana"];

const experience = [
  {
    title: "Data Engineer",
    org: "Summit Lithium Technology",
    dates: "May 2023 – Present",
    note: "Calgary, AB · direct-lithium-extraction clean-tech",
    points: [
      "Architected and operate a production data platform that orchestrates ~40 Airflow pipelines, generated from configuration instead of hand-coded.",
      "Built incremental MySQL → Parquet → Azure Blob extraction with watermark-based change tracking across multiple data domains.",
      "Designed a multi-zone Snowflake warehouse (landing → staging → curated) with change-data-capture, role-based access control, and data-masking policies.",
      "Shipped changes through Azure DevOps CI/CD with isolated staging and production environments; owned the platform's Terraform, containers, Linux hosting, backups, and runbooks.",
    ],
  },
  {
    title: "Data & Analytics Engineer",
    org: "Rio Tinto (Oyu Tolgoi LLC)",
    dates: "2017 – 2021",
    note: "Mongolia · one of the world's largest copper-gold mines",
    points: [
      "Built ETL pipelines connecting SAP, Ariba, and operational sources into Azure for cleaner, more accessible reporting.",
      "Automated dashboards and SQL validation checks that cut manual reporting and recurring data-quality issues.",
    ],
  },
  {
    title: "Process Automation & IT/OT",
    org: "Rio Tinto (Oyu Tolgoi LLC)",
    dates: "2011 – 2017",
    note: "Mongolia",
    points: [
      "Integrated PLC / concentrator data into live reporting and enhanced SCADA/HMI logic; built automation tools in C#, Python, and APIs.",
      "Maintained mission-critical IT/OT systems (SAP, OSIsoft PI, SCADA, networking) for remote mine sites and 24/7 production.",
    ],
  },
];

const projects = [
  {
    tag: "Data platform",
    title: "Cloud data platform (Airflow → Snowflake)",
    desc: "End-to-end pipeline platform: config-driven Airflow DAGs, incremental extraction with CDC, and a multi-zone Snowflake warehouse — all deployed through CI/CD across staging and prod.",
    stack: ["Airflow", "Snowflake", "Azure", "Python", "CI/CD"],
  },
  {
    tag: "Personal · DevSecOps",
    title: "Multi-environment IaC platform on Proxmox",
    desc: "A homelab-to-production infra platform I design, build, and run on personal time: three isolated Terraform environments (dev/staging/prod) deploying immutable Fedora CoreOS VMs via Ignition, six Azure DevOps pipelines with OIDC workload-identity federation instead of stored Azure service-principal secrets, and a fully tested backup/DR process with a completed restore drill.",
    stack: ["Terraform", "Fedora CoreOS", "Proxmox", "Azure DevOps", "OIDC"],
  },
  {
    tag: "Personal · Platform ops",
    title: "Self-service ops automation for the homelab",
    desc: "Podman Quadlets run every container as a native systemd unit — scheduler, templated workers, a scheduled reaper timer — with automatic restart and no container daemon. On top of that I built 12 custom runbook-style automations covering VM deploys, cluster health checks, backup/DR, monitoring, and IaC quality gates (tflint, checkov, terraform-docs).",
    stack: ["Podman Quadlets", "systemd", "Terraform", "tflint/checkov", "Bash"],
  },
  {
    tag: "Applied AI",
    title: "Snowflake RAG & semantic search",
    desc: "Document-ingestion and retrieval-augmented-generation apps on Snowflake Cortex Search, putting searchable answers over internal documents in front of non-technical teams.",
    stack: ["Snowflake Cortex", "Python", "Streamlit", "LLMs"],
  },
];
---

<Layout>
  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <p class="eyebrow">Data Platform · DataOps · Cloud Data Engineering</p>
      <h1>Hi, I'm Tsogt — I build and run<br /><span class="accent">cloud data platforms</span>, end to end.</h1>
      <p class="hero-sub">
        I like owning the whole thing — from the pipeline that pulls the data, to the Snowflake
        warehouse it lands in, to the Terraform and CI/CD underneath. Not just one slice of it.
      </p>
      <p class="hero-meta">📍 Based in Calgary, AB · happy to work hybrid across Alberta</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#projects">View projects</a>
        <a class="btn" href="/resume.pdf">Résumé (PDF)</a>
        <a class="btn" href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn" href={contact.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </header>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="eyebrow">About</p>
      <h2 class="section-title">A bit about me</h2>
      <div class="about-grid">
        <p class="first">
          I'm a data platform engineer based in Calgary. For the last 5+ years I've been building data
          pipelines and the cloud platforms they run on — and before that I spent years in analytics,
          BI, and industrial systems, so I've gotten to see data from a lot of different angles.
        </p>
        <p>
          My path here wasn't exactly a straight line. I started out in process and automation
          engineering at one of the world's largest mines, got pulled into data and analytics along
          the way, moved to Canada and retrained (diplomas in Data Analytics and Computer
          Programming), and I've been building data platforms ever since. That mix means I'm just as
          comfortable talking with operations folks as I am with a data team — which turns out to be
          pretty handy for energy, industrial, and clean-tech work.
        </p>
        <p>
          A few things I genuinely care about: pipelines that are reliable and easy to keep an eye on,
          infrastructure you can rebuild from code, and security that's baked in by design rather than
          left to whether everyone remembers the rules. And when I'm off the clock, I'm usually
          tinkering with the same ideas on my home lab.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="container">
      <p class="eyebrow">Skills</p>
      <h2 class="section-title">Toolbox</h2>
      <p class="section-lead">Here's the stack I reach for day to day — plus a few things I'm actively leveling up on.</p>
      <div class="skill-grid">
        {skillGroups.map((group) => (
          <div class="skill-card">
            <h3>{group.title}</h3>
            <div class="chips">
              {group.skills.map((s) => <span class="chip">{s}</span>)}
            </div>
          </div>
        ))}
        <div class="skill-card">
          <h3>Currently leveling up</h3>
          <div class="chips">
            {growing.map((s) => <span class="chip grow">{s}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <p class="eyebrow">Experience</p>
      <h2 class="section-title">Where I've built things</h2>
      <div class="timeline">
        {experience.map((job) => (
          <article class="job">
            <div class="job-head">
              <div>
                <span class="job-title">{job.title}</span>
                <span class="job-org"> · {job.org}</span>
              </div>
              <span class="job-dates">{job.dates}</span>
            </div>
            <p class="section-lead" style="margin: 4px 0 0; font-size: 0.9rem;">{job.note}</p>
            <ul>
              {job.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <p class="eyebrow">Projects</p>
      <h2 class="section-title">Selected work</h2>
      <p class="section-lead">A few things I've built. Some details are kept general where the work belongs to an employer.</p>
      <div class="project-grid">
        {projects.map((p) => (
          <article class="project-card">
            <span class="tag">{p.tag}</span>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <div class="stack">
              {p.stack.map((s) => <span>{s}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h2 class="section-title">Let's talk</h2>
      <p class="contact-lead">
        I'm currently open to Data Platform, DataOps, or Data Engineering roles — hybrid around Calgary,
        or elsewhere in Alberta. If you're building something with data and want a hand from someone
        who can take it end to end, I'd love to hear from you.
      </p>
      <div class="contact-links">
        <a class="btn btn-primary" href={`mailto:${contact.email}`}>Email me</a>
        <a class="btn" href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn" href={contact.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
